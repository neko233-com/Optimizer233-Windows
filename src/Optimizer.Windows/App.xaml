<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Optimizer_Windows.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Optimizer_Windows">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <SolidColorBrush x:Key="ShellSurfaceBrush" Color="#141A23" />
            <SolidColorBrush x:Key="ShellCardBrush" Color="#1D2430" />
            <SolidColorBrush x:Key="ShellCardMutedBrush" Color="#111723" />
            <SolidColorBrush x:Key="ShellBorderBrush" Color="#2C3747" />
            <SolidColorBrush x:Key="ShellAccentBrush" Color="#6FD1B8" />

            <Style x:Key="SectionCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource ShellCardBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource ShellBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="20" />
                <Setter Property="Padding" Value="20" />
            </Style>

            <Style x:Key="MetricValueTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="28" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="MetricLabelTextStyle" TargetType="TextBlock">
                <Setter Property="Opacity" Value="0.72" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
