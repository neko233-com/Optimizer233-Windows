<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Optimizer_Windows.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Optimizer_Windows"
    RequestedTheme="Dark">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <SolidColorBrush x:Key="ShellSurfaceBrush" Color="#05060A" />
            <SolidColorBrush x:Key="ShellPaneBrush" Color="#090B12" />
            <SolidColorBrush x:Key="ShellCardMutedBrush" Color="#0D1017" />
            <SolidColorBrush x:Key="ShellBorderBrush" Color="#45202C" />
            <SolidColorBrush x:Key="ShellBorderSoftBrush" Color="#27202B" />
            <SolidColorBrush x:Key="ShellAccentBrush" Color="#FF355D" />
            <SolidColorBrush x:Key="ShellAccentSecondaryBrush" Color="#FF6A8A" />
            <SolidColorBrush x:Key="ShellAccentDimBrush" Color="#874057" />
            <SolidColorBrush x:Key="ShellTextMutedBrush" Color="#B7C0CF" />
            <SolidColorBrush x:Key="ShellTextFaintBrush" Color="#788295" />
            <SolidColorBrush x:Key="ShellControlBrush" Color="#111520" />
            <SolidColorBrush x:Key="ShellControlElevatedBrush" Color="#151A26" />
            <SolidColorBrush x:Key="ShellFloatingBrush" Color="#11141D" />

            <LinearGradientBrush x:Key="ShellAccentFillBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FF2248" Offset="0" />
                <GradientStop Color="#FF3B63" Offset="0.5" />
                <GradientStop Color="#FF7846" Offset="1" />
            </LinearGradientBrush>

            <LinearGradientBrush x:Key="ShellSecondaryFillBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#141925" Offset="0" />
                <GradientStop Color="#111520" Offset="1" />
            </LinearGradientBrush>

            <LinearGradientBrush x:Key="ShellCardBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#141924" Offset="0" />
                <GradientStop Color="#0A0D14" Offset="0.68" />
                <GradientStop Color="#0C1018" Offset="1" />
            </LinearGradientBrush>

            <LinearGradientBrush x:Key="ShellElevatedBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1B1018" Offset="0" />
                <GradientStop Color="#0B0F17" Offset="0.4" />
                <GradientStop Color="#120B12" Offset="1" />
            </LinearGradientBrush>

            <LinearGradientBrush x:Key="ShellHeroBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#231018" Offset="0" />
                <GradientStop Color="#0B0F17" Offset="0.38" />
                <GradientStop Color="#0B101A" Offset="0.72" />
                <GradientStop Color="#140A12" Offset="1" />
            </LinearGradientBrush>

            <Style x:Key="SectionCardStyle" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource ShellCardBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource ShellBorderSoftBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="16" />
                <Setter Property="Padding" Value="22" />
            </Style>

            <Style x:Key="HeroPanelStyle" TargetType="Border" BasedOn="{StaticResource SectionCardStyle}">
                <Setter Property="Background" Value="{StaticResource ShellHeroBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource ShellAccentDimBrush}" />
                <Setter Property="Padding" Value="22" />
            </Style>

            <Style x:Key="InsetPanelStyle" TargetType="Border">
                <Setter Property="Background" Value="#121722" />
                <Setter Property="BorderBrush" Value="{StaticResource ShellBorderSoftBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="Padding" Value="16" />
            </Style>

            <Style x:Key="DataRowCardStyle" TargetType="Border" BasedOn="{StaticResource InsetPanelStyle}">
                <Setter Property="Background" Value="#11151F" />
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="Padding" Value="18,14" />
            </Style>

            <Style x:Key="PillTagBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="#16111A" />
                <Setter Property="BorderBrush" Value="{StaticResource ShellBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="999" />
                <Setter Property="Padding" Value="12,4" />
                <Setter Property="MinHeight" Value="28" />
                <Setter Property="MinWidth" Value="72" />
            </Style>

            <Style x:Key="StatePillBorderStyle" TargetType="Border" BasedOn="{StaticResource PillTagBorderStyle}">
                <Setter Property="Padding" Value="13,5" />
                <Setter Property="MinWidth" Value="92" />
                <Setter Property="MinHeight" Value="30" />
            </Style>

            <Style x:Key="MetricKeyTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource ShellTextFaintBrush}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontFamily" Value="Bahnschrift" />
                <Setter Property="CharacterSpacing" Value="80" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="PillLabelTextStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Bahnschrift" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="TextAlignment" Value="Center" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="TextWrapping" Value="NoWrap" />
            </Style>

            <Style x:Key="MetricValueTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="28" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontFamily" Value="Bahnschrift" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="MetricLabelTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource ShellTextMutedBrush}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontFamily" Value="Bahnschrift" />
                <Setter Property="CharacterSpacing" Value="120" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource ShellAccentFillBrush}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="BorderBrush" Value="#80FF8AA2" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="18,11" />
                <Setter Property="MinHeight" Value="44" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="FontFamily" Value="Bahnschrift" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="13" />
            </Style>

            <Style x:Key="SecondaryActionButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="{StaticResource ShellSecondaryFillBrush}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="BorderBrush" Value="{StaticResource ShellBorderSoftBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="18,11" />
                <Setter Property="MinHeight" Value="44" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="FontFamily" Value="Bahnschrift" />
                <Setter Property="FontSize" Value="13" />
            </Style>

            <Style x:Key="TechChipStyle" TargetType="Border">
                <Setter Property="Background" Value="#16111A" />
                <Setter Property="BorderBrush" Value="{StaticResource ShellBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="999" />
                <Setter Property="Padding" Value="12,5" />
            </Style>

            <Style x:Key="PresetCardStyle" TargetType="Border" BasedOn="{StaticResource SectionCardStyle}">
                <Setter Property="Padding" Value="18" />
            </Style>

            <Style TargetType="TextBox">
                <Setter Property="Background" Value="{StaticResource ShellControlBrush}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="BorderBrush" Value="{StaticResource ShellBorderSoftBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="12,10" />
                <Setter Property="SelectionHighlightColor" Value="{StaticResource ShellAccentSecondaryBrush}" />
            </Style>

            <Style TargetType="AutoSuggestBox">
                <Setter Property="Background" Value="{StaticResource ShellControlBrush}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="BorderBrush" Value="{StaticResource ShellBorderSoftBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Padding" Value="12,10" />
            </Style>

            <Style TargetType="ComboBox">
                <Setter Property="Background" Value="{StaticResource ShellControlBrush}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="BorderBrush" Value="{StaticResource ShellBorderSoftBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="12" />
            </Style>

            <Style TargetType="ListView">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
            </Style>

            <Style TargetType="ListViewItem">
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="0" />
                <Setter Property="MinHeight" Value="0" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Stretch" />
            </Style>

            <Style TargetType="ProgressBar">
                <Setter Property="Foreground" Value="{StaticResource ShellAccentSecondaryBrush}" />
                <Setter Property="Background" Value="#221723" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
