<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Optimizer_Windows.Pages.FeaturesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Optimizer_Windows.Models"
    Background="{StaticResource ShellSurfaceBrush}"
    Loaded="Page_Loaded"
    mc:Ignorable="d">
    <Page.Resources>
        <Style x:Key="FeatureGridViewItemStyle" TargetType="GridViewItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Padding="20" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource HeroPanelStyle}">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="340" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="8">
                        <Border Style="{StaticResource TechChipStyle}" HorizontalAlignment="Left">
                            <TextBlock x:Name="HeroEyebrowText" FontFamily="Bahnschrift" Foreground="{StaticResource ShellAccentSecondaryBrush}" />
                        </Border>
                        <TextBlock x:Name="PageTitleText" FontSize="28" FontFamily="Bahnschrift" FontWeight="SemiBold" />
                        <TextBlock x:Name="PageSubtitleText" Foreground="{StaticResource ShellTextMutedBrush}" TextWrapping="Wrap" />
                    </StackPanel>

                    <Border Grid.Column="1" Style="{StaticResource InsetPanelStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock x:Name="StatusCardTitleText" FontSize="18" FontFamily="Bahnschrift" FontWeight="SemiBold" />
                            <TextBlock x:Name="StatusText" Foreground="{StaticResource ShellTextMutedBrush}" TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button x:Name="RefreshButton" Click="RefreshButton_Click" Style="{StaticResource SecondaryActionButtonStyle}" />
                                <Button x:Name="OpenWindowsFeaturesButton" Click="OpenWindowsFeaturesButton_Click" Style="{StaticResource PrimaryActionButtonStyle}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock x:Name="EnabledMetricLabelText" Foreground="{StaticResource ShellTextMutedBrush}" FontFamily="Bahnschrift" />
                        <TextBlock x:Name="EnabledMetricValueText" Style="{StaticResource MetricValueTextStyle}" />
                        <TextBlock x:Name="EnabledMetricHintText" Foreground="{StaticResource ShellTextFaintBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource SectionCardStyle}" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock x:Name="RestartMetricLabelText" Foreground="{StaticResource ShellTextMutedBrush}" FontFamily="Bahnschrift" />
                        <TextBlock x:Name="RestartMetricValueText" Style="{StaticResource MetricValueTextStyle}" />
                        <TextBlock x:Name="RestartMetricHintText" Foreground="{StaticResource ShellTextFaintBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock x:Name="HighRiskMetricLabelText" Foreground="{StaticResource ShellTextMutedBrush}" FontFamily="Bahnschrift" />
                        <TextBlock x:Name="HighRiskMetricValueText" Style="{StaticResource MetricValueTextStyle}" />
                        <TextBlock x:Name="HighRiskMetricHintText" Foreground="{StaticResource ShellTextFaintBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2" Style="{StaticResource SectionCardStyle}" Padding="18">
                <StackPanel Spacing="12">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <AutoSuggestBox
                            x:Name="FeatureSearchBox"
                            PlaceholderText="Search features"
                            TextChanged="FeatureSearchBox_TextChanged" />
                        <Button x:Name="OpenSystemRestoreButton" Grid.Column="1" Click="OpenSystemRestoreButton_Click" Style="{StaticResource SecondaryActionButtonStyle}" />
                    </Grid>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" HorizontalScrollMode="Enabled" VerticalScrollMode="Disabled" VerticalScrollBarVisibility="Disabled">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button x:Name="ShowAllButton" Click="ShowAllButton_Click" Style="{StaticResource SecondaryActionButtonStyle}" />
                            <Button x:Name="FrontendFilterButton" Click="FrontendFilterButton_Click" Style="{StaticResource SecondaryActionButtonStyle}" />
                            <Button x:Name="BackendFilterButton" Click="BackendFilterButton_Click" Style="{StaticResource SecondaryActionButtonStyle}" />
                            <Button x:Name="GameDevFilterButton" Click="GameDevFilterButton_Click" Style="{StaticResource SecondaryActionButtonStyle}" />
                            <Button x:Name="GamerFilterButton" Click="GamerFilterButton_Click" Style="{StaticResource SecondaryActionButtonStyle}" />
                        </StackPanel>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <Border Grid.Row="3" Style="{StaticResource SectionCardStyle}" Padding="0">
                <Grid>
                    <Grid RowSpacing="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Background="#100D15" BorderBrush="{StaticResource ShellBorderSoftBrush}" BorderThickness="0,0,0,1" Padding="18,12">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3.4*" />
                                    <ColumnDefinition Width="1.5*" />
                                    <ColumnDefinition Width="1.1*" />
                                    <ColumnDefinition Width="0.95*" />
                                    <ColumnDefinition Width="1.05*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="ColumnNameText" Foreground="{StaticResource ShellTextFaintBrush}" FontFamily="Bahnschrift" />
                                <TextBlock x:Name="ColumnAudienceText" Grid.Column="1" Foreground="{StaticResource ShellTextFaintBrush}" FontFamily="Bahnschrift" />
                                <TextBlock x:Name="ColumnStateText" Grid.Column="2" Foreground="{StaticResource ShellTextFaintBrush}" FontFamily="Bahnschrift" />
                                <TextBlock x:Name="ColumnRiskText" Grid.Column="3" Foreground="{StaticResource ShellTextFaintBrush}" FontFamily="Bahnschrift" />
                                <TextBlock x:Name="ColumnToggleText" Grid.Column="4" Foreground="{StaticResource ShellTextFaintBrush}" FontFamily="Bahnschrift" />
                            </Grid>
                        </Border>

                        <ListView
                            x:Name="FeaturesListView"
                            Grid.Row="1"
                            ItemsSource="{x:Bind VisibleFeatures, Mode=OneWay}"
                            SelectionMode="None"
                            IsItemClickEnabled="False"
                            Background="Transparent"
                            BorderThickness="0"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:WindowsFeatureItem">
                                    <Border BorderBrush="{StaticResource ShellBorderSoftBrush}" BorderThickness="0,0,0,1" Padding="18,14">
                                        <Grid ColumnSpacing="12" VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="3.4*" />
                                                <ColumnDefinition Width="1.5*" />
                                                <ColumnDefinition Width="1.1*" />
                                                <ColumnDefinition Width="0.95*" />
                                                <ColumnDefinition Width="1.05*" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{x:Bind DisplayName}" FontSize="18" FontFamily="Bahnschrift" FontWeight="SemiBold" TextWrapping="WrapWholeWords" />
                                                <TextBlock Text="{x:Bind Description}" Foreground="{StaticResource ShellTextMutedBrush}" TextWrapping="WrapWholeWords" MaxLines="2" />
                                            </StackPanel>

                                            <TextBlock Grid.Column="1" Text="{x:Bind AudienceText}" Foreground="{StaticResource ShellTextMutedBrush}" TextWrapping="WrapWholeWords" VerticalAlignment="Center" />

                                            <StackPanel Grid.Column="2" Spacing="6" VerticalAlignment="Center">
                                                <Border
                                                    Style="{StaticResource StatePillBorderStyle}"
                                                    Background="{x:Bind StateBackground}"
                                                    BorderBrush="{x:Bind StateBorder}"
                                                    HorizontalAlignment="Left">
                                                    <TextBlock Style="{StaticResource PillLabelTextStyle}" Text="{x:Bind StateText}" Foreground="{x:Bind StateBrush}" />
                                                </Border>
                                                <TextBlock Text="{x:Bind RestartText}" Style="{StaticResource MetricKeyTextStyle}" />
                                            </StackPanel>

                                            <Border
                                                Grid.Column="3"
                                                Style="{StaticResource StatePillBorderStyle}"
                                                Background="{x:Bind RiskBackground}"
                                                BorderBrush="{x:Bind RiskBorder}"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Left">
                                                <TextBlock Style="{StaticResource PillLabelTextStyle}" Text="{x:Bind RiskLabel}" Foreground="{x:Bind RiskBrush}" />
                                            </Border>

                                            <Grid Grid.Column="4" ColumnSpacing="10" VerticalAlignment="Center">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <ToggleSwitch
                                                    x:Name="FeatureToggle"
                                                    Toggled="FeatureToggle_Toggled"
                                                    IsOn="{x:Bind IsEnabled, Mode=TwoWay}"
                                                    IsEnabled="{x:Bind CanToggle, Mode=OneWay}"
                                                    Tag="{x:Bind}"
                                                    OffContent="Off"
                                                    OnContent="On" />
                                                <ProgressRing Grid.Column="1" Width="18" Height="18" IsActive="{x:Bind IsBusy, Mode=OneWay}" />
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>

                    <TextBlock
                        x:Name="EmptyStateText"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource ShellTextMutedBrush}"
                        Visibility="Collapsed" />
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
