<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Optimizer_Windows.Pages.OfficePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Optimizer_Windows.Models"
    Background="{StaticResource ShellSurfaceBrush}"
    Loaded="Page_Loaded"
    mc:Ignorable="d">
    <Grid Padding="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource SectionCardStyle}">
            <StackPanel Spacing="12">
                <TextBlock x:Name="PageTitleText" FontSize="22" FontFamily="Bahnschrift" FontWeight="SemiBold" Text="Office Management" />
                <TextBlock x:Name="PageSubtitleText" Foreground="{StaticResource ShellTextMutedBrush}" TextWrapping="Wrap" Text="Detect installed Office products and jump to official Microsoft installation resources." />
                <TextBlock x:Name="StatusText" Foreground="{StaticResource ShellTextMutedBrush}" TextWrapping="Wrap" />
                <ListView ItemsSource="{x:Bind OfficeProducts, Mode=OneWay}" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:OfficeInstallInfo">
                            <StackPanel Padding="0,8" Spacing="4">
                                <TextBlock FontSize="16" FontFamily="Bahnschrift" FontWeight="SemiBold" Text="{x:Bind DisplayName}" />
                                <TextBlock Foreground="{StaticResource ShellTextMutedBrush}" Text="{x:Bind Publisher}" TextWrapping="Wrap" />
                                <TextBlock Foreground="{StaticResource ShellTextFaintBrush}" Text="{x:Bind DisplayVersion}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button x:Name="RefreshButton" Grid.Column="0" Click="RefreshButton_Click" Style="{StaticResource SecondaryActionButtonStyle}" Content="Refresh" />
            <Button x:Name="OpenDownloadButton" Grid.Column="1" Click="OpenDownloadButton_Click" Style="{StaticResource SecondaryActionButtonStyle}" Content="Open Microsoft 365 Download" />
            <Button x:Name="OpenDeploymentToolButton" Grid.Column="2" Click="OpenDeploymentToolButton_Click" Style="{StaticResource SecondaryActionButtonStyle}" Content="Open ODT Download" />
            <Button x:Name="OpenAppsFeaturesButton" Grid.Column="3" Click="OpenAppsFeaturesButton_Click" Style="{StaticResource PrimaryActionButtonStyle}" Content="Open Installed Apps" />
        </Grid>
    </Grid>
</Page>
