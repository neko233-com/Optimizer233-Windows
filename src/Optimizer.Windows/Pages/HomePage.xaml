<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Optimizer_Windows.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Optimizer_Windows.Pages"
    xmlns:models="using:Optimizer_Windows.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Loaded="Page_Loaded"
    mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24,20,24,32" Spacing="24">
            <Border Background="{StaticResource ShellElevatedBrush}" BorderBrush="{StaticResource ShellAccentDimBrush}" BorderThickness="1" CornerRadius="10" Padding="24">
                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="320" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="10">
                        <Border Style="{StaticResource TechChipStyle}" HorizontalAlignment="Left">
                            <TextBlock x:Name="HeroEyebrowText" FontFamily="Bahnschrift" Foreground="{StaticResource ShellAccentSecondaryBrush}" Text="SYSTEM STATUS" />
                        </Border>
                        <TextBlock x:Name="PageTitleText" Style="{StaticResource TitleTextBlockStyle}" Text="System Overview" />
                        <TextBlock x:Name="PageSubtitleText" Foreground="{StaticResource ShellTextMutedBrush}" Text="WinUI 3 desktop shell for Windows optimization, health checks, and hardware inspection." TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button x:Name="RefreshButton" Click="RefreshButton_Click" Content="Refresh" Style="{StaticResource PrimaryActionButtonStyle}" />
                            <Border Style="{StaticResource TechChipStyle}" VerticalAlignment="Center">
                                <TextBlock x:Name="StatusChipText" FontFamily="Bahnschrift" Foreground="{StaticResource ShellAccentSecondaryBrush}" Text="LIVE TELEMETRY" />
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="1" Style="{StaticResource SectionCardStyle}" Background="#0B0A0F">
                        <StackPanel Spacing="12">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="QuickStatusTitleText" FontSize="18" FontFamily="Bahnschrift" FontWeight="SemiBold" Text="Quick Status" />
                                <ProgressRing x:Name="LoadingRing" Width="24" Height="24" IsActive="False" />
                            </Grid>
                            <TextBlock x:Name="StatusText" Foreground="{StaticResource ShellTextMutedBrush}" TextWrapping="Wrap" />
                            <TextBlock x:Name="HostNameText" Style="{StaticResource MetricValueTextStyle}" />
                            <TextBlock x:Name="DeviceText" Foreground="{StaticResource ShellTextMutedBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid ColumnSpacing="16" RowSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource SectionCardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock x:Name="DeviceLabelText" Style="{StaticResource MetricLabelTextStyle}" Text="Device" />
                        <TextBlock x:Name="DeviceSummaryText" Style="{StaticResource MetricValueTextStyle}" />
                        <TextBlock x:Name="DeviceModelText" Foreground="{StaticResource ShellTextMutedBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource SectionCardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock x:Name="WindowsLabelText" Style="{StaticResource MetricLabelTextStyle}" Text="Windows" />
                        <TextBlock x:Name="WindowsText" Style="{StaticResource MetricValueTextStyle}" />
                        <TextBlock x:Name="BootText" Foreground="{StaticResource ShellTextMutedBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource SectionCardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock x:Name="ProcessorLabelText" Style="{StaticResource MetricLabelTextStyle}" Text="Processor" />
                        <TextBlock x:Name="ProcessorText" Style="{StaticResource MetricValueTextStyle}" />
                        <TextBlock x:Name="GraphicsText" Foreground="{StaticResource ShellTextMutedBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource SectionCardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock x:Name="MemoryLabelText" Style="{StaticResource MetricLabelTextStyle}" Text="Memory" />
                        <TextBlock x:Name="MemoryText" Style="{StaticResource MetricValueTextStyle}" />
                        <ProgressBar x:Name="MemoryUsageBar" Height="8" Maximum="100" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Grid.Column="0" Style="{StaticResource SectionCardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock x:Name="StorageLabelText" Style="{StaticResource MetricLabelTextStyle}" Text="Storage" />
                        <TextBlock x:Name="StorageText" Style="{StaticResource MetricValueTextStyle}" />
                        <TextBlock x:Name="NetworkText" Foreground="{StaticResource ShellTextMutedBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource SectionCardStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock x:Name="FocusLabelText" Style="{StaticResource MetricLabelTextStyle}" Text="Focus" />
                        <TextBlock x:Name="FocusTitleText" FontSize="20" FontFamily="Bahnschrift" FontWeight="SemiBold" Text="Safe maintenance first" />
                        <TextBlock x:Name="FocusBodyText" Foreground="{StaticResource ShellTextMutedBrush}" Text="This build opens trusted Windows tools and shows live health data. No destructive one-click cleaning in v1." TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource SectionCardStyle}">
                <StackPanel Spacing="16">
                    <TextBlock x:Name="DriveHealthTitleText" FontSize="20" FontFamily="Bahnschrift" FontWeight="SemiBold" Text="Drive Health" />
                    <ListView ItemsSource="{x:Bind Drives, Mode=OneWay}" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:DiskUsage">
                                <Grid Padding="0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="96" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="4">
                                        <TextBlock FontSize="16" FontFamily="Bahnschrift" FontWeight="SemiBold" Text="{x:Bind Name}" />
                                        <TextBlock Foreground="{StaticResource ShellTextMutedBrush}" Text="{x:Bind Summary}" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <ProgressBar Grid.Column="1" Height="8" VerticalAlignment="Center" Maximum="100" Value="{x:Bind UsagePercent}" />
                                    <TextBlock Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" Text="{x:Bind UsageLabel}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
