<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Optimizer_Windows.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{StaticResource ShellSurfaceBrush}"
    mc:Ignorable="d">
    <Grid Padding="20" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeroPanelStyle}">
            <StackPanel Spacing="8">
                <Border Style="{StaticResource TechChipStyle}" HorizontalAlignment="Left">
                    <TextBlock x:Name="PageEyebrowText" FontFamily="Bahnschrift" Foreground="{StaticResource ShellAccentSecondaryBrush}" />
                </Border>
                <TextBlock x:Name="PageTitleText" FontSize="26" FontFamily="Bahnschrift" FontWeight="SemiBold" />
                <TextBlock x:Name="PageSubtitleText" Foreground="{StaticResource ShellTextMutedBrush}" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.95*" />
                <ColumnDefinition Width="1.05*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}" Padding="18">
                <StackPanel Spacing="16">
                    <TextBlock x:Name="BehaviorTitleText" FontSize="22" FontFamily="Bahnschrift" FontWeight="SemiBold" />

                    <Border Style="{StaticResource InsetPanelStyle}" Padding="14">
                        <StackPanel Spacing="8">
                            <TextBlock x:Name="StartupTitleText" FontSize="18" FontFamily="Bahnschrift" FontWeight="SemiBold" />
                            <TextBlock x:Name="StartupBodyText" Foreground="{StaticResource ShellTextMutedBrush}" TextWrapping="Wrap" />
                            <ToggleSwitch x:Name="StartupToggle" Toggled="StartupToggle_Toggled" OffContent="Off" OnContent="On" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource InsetPanelStyle}" Padding="14">
                        <StackPanel Spacing="8">
                            <TextBlock x:Name="LanguageTitleText" FontSize="18" FontFamily="Bahnschrift" FontWeight="SemiBold" />
                            <TextBlock x:Name="LanguageBodyText" Foreground="{StaticResource ShellTextMutedBrush}" TextWrapping="Wrap" />
                            <TextBlock x:Name="LanguageValueText" FontFamily="Bahnschrift" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource SectionCardStyle}" Padding="18">
                <StackPanel Spacing="16">
                    <TextBlock x:Name="UpdateTitleText" FontSize="22" FontFamily="Bahnschrift" FontWeight="SemiBold" />
                    <TextBlock x:Name="UpdateBodyText" Foreground="{StaticResource ShellTextMutedBrush}" TextWrapping="Wrap" />

                    <Grid ColumnSpacing="14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource InsetPanelStyle}" Padding="14">
                            <StackPanel Spacing="6">
                                <TextBlock x:Name="CurrentVersionLabelText" Style="{StaticResource MetricLabelTextStyle}" />
                                <TextBlock x:Name="CurrentVersionValueText" FontSize="18" FontFamily="Bahnschrift" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource InsetPanelStyle}" Padding="14">
                            <StackPanel Spacing="6">
                                <TextBlock x:Name="LatestVersionLabelText" Style="{StaticResource MetricLabelTextStyle}" />
                                <TextBlock x:Name="LatestVersionValueText" FontSize="18" FontFamily="Bahnschrift" FontWeight="SemiBold" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <StackPanel Spacing="8">
                        <TextBlock x:Name="UpdateSourceLabelText" FontFamily="Bahnschrift" FontWeight="SemiBold" />
                        <ComboBox x:Name="UpdateSourceComboBox" DisplayMemberPath="DisplayName" SelectedValuePath="Id" SelectionChanged="UpdateSourceComboBox_SelectionChanged" />
                    </StackPanel>

                    <StackPanel x:Name="CustomMirrorPanel" Spacing="8" Visibility="Collapsed">
                        <TextBlock x:Name="CustomMirrorLabelText" FontFamily="Bahnschrift" FontWeight="SemiBold" />
                        <TextBox x:Name="CustomMirrorPrefixBox" />
                        <TextBlock x:Name="CustomMirrorHintText" Foreground="{StaticResource ShellTextFaintBrush}" TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="SaveSourceButton" Click="SaveSourceButton_Click" Style="{StaticResource SecondaryActionButtonStyle}" />
                        <Button x:Name="CheckUpdatesButton" Click="CheckUpdatesButton_Click" Style="{StaticResource PrimaryActionButtonStyle}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="DownloadUpdateButton" Click="DownloadUpdateButton_Click" Style="{StaticResource SecondaryActionButtonStyle}" IsEnabled="False" />
                        <Button x:Name="OpenNotesButton" Click="OpenNotesButton_Click" Style="{StaticResource SecondaryActionButtonStyle}" IsEnabled="False" />
                        <Button x:Name="OpenReleasesButton" Click="OpenReleasesButton_Click" Style="{StaticResource SecondaryActionButtonStyle}" />
                    </StackPanel>

                    <TextBlock x:Name="UpdateStatusText" Foreground="{StaticResource ShellTextMutedBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
