<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Optimizer_Windows.Pages.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Optimizer_Windows.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24,20,24,32" Spacing="20">
            <TextBlock x:Name="PageTitleText" Style="{StaticResource TitleTextBlockStyle}" Text="About" />

            <Border Style="{StaticResource SectionCardStyle}">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="IntroTitleText" FontSize="22" FontWeight="SemiBold" Text="Optimizer Windows" />
                    <TextBlock x:Name="IntroBody1Text" Opacity="0.78" Text="Windows-only utility shell built with WinUI 3 and latest stable Windows App SDK." TextWrapping="Wrap" />
                    <TextBlock x:Name="IntroBody2Text" Opacity="0.78" Text="Current scope: live device overview, hardware inspection, and safe deep links into native optimization tools." TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SectionCardStyle}">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="RoadmapTitleText" FontSize="20" FontWeight="SemiBold" Text="Roadmap" />
                    <TextBlock x:Name="RoadmapItem1Text" Text="1. Smart startup-impact analyzer" />
                    <TextBlock x:Name="RoadmapItem2Text" Text="2. Disk cleanup recommendations with file-size scoring" />
                    <TextBlock x:Name="RoadmapItem3Text" Text="3. Service and scheduled-task insight panel" />
                    <TextBlock x:Name="RoadmapItem4Text" Text="4. Exportable hardware report for troubleshooting" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
