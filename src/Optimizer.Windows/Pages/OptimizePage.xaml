<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Optimizer_Windows.Pages.OptimizePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Optimizer_Windows.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Optimizer_Windows.Models"
    Loaded="Page_Loaded"
    mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24,20,24,32" Spacing="24">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="6">
                    <TextBlock x:Name="PageTitleText" Style="{StaticResource TitleTextBlockStyle}" Text="Optimize" />
                    <TextBlock x:Name="PageSubtitleText" Opacity="0.78" Text="Safe shortcuts into trusted Windows maintenance surfaces." />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <ProgressRing x:Name="LoadingRing" Width="24" Height="24" IsActive="False" />
                    <Button x:Name="RefreshButton" Click="RefreshButton_Click" Content="Refresh" Style="{StaticResource SecondaryActionButtonStyle}" />
                </StackPanel>
            </Grid>

            <TextBlock x:Name="StatusText" Foreground="{StaticResource ShellTextMutedBrush}" />

            <Border Background="{StaticResource ShellElevatedBrush}" BorderBrush="{StaticResource ShellAccentDimBrush}" BorderThickness="1" CornerRadius="10" Padding="24">
                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="320" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="10">
                        <Border Style="{StaticResource TechChipStyle}" HorizontalAlignment="Left">
                            <TextBlock x:Name="HeroEyebrowText" FontFamily="Bahnschrift" Foreground="{StaticResource ShellAccentSecondaryBrush}" Text="TACTICAL CONTROL" />
                        </Border>
                        <TextBlock x:Name="HeroTitleText" FontSize="32" FontFamily="Bahnschrift" FontWeight="Bold" TextWrapping="Wrap" Text="Dark ops control center for Windows 11" />
                        <TextBlock x:Name="HeroBodyText" Foreground="{StaticResource ShellTextMutedBrush}" TextWrapping="Wrap" Text="Inspired by sharper optimizer layouts, rebuilt as a safer WinUI 3 command deck with presets, explanations, and native-tool launch flows." />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button x:Name="OpenSelectedButton" Click="OpenSelectedButton_Click" Style="{StaticResource PrimaryActionButtonStyle}" Content="Open Selected" />
                            <Button x:Name="ExportPlanButton" Click="ExportPlanButton_Click" Style="{StaticResource SecondaryActionButtonStyle}" Content="Export Plan" />
                        </StackPanel>
                    </StackPanel>

                    <Border Grid.Column="1" Style="{StaticResource SectionCardStyle}" Background="#0B0A0F">
                        <StackPanel Spacing="14">
                            <TextBlock x:Name="TempSnapshotTitleText" FontSize="20" FontFamily="Bahnschrift" FontWeight="SemiBold" Text="Temp Folder Snapshot" />
                            <TextBlock x:Name="TempPathText" Foreground="{StaticResource ShellTextFaintBrush}" TextWrapping="Wrap" />
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="4">
                                    <TextBlock x:Name="TempFilesLabelText" Style="{StaticResource MetricLabelTextStyle}" Text="Files" />
                                    <TextBlock x:Name="TempFileCountText" FontSize="24" FontFamily="Bahnschrift" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock x:Name="TempSizeLabelText" Style="{StaticResource MetricLabelTextStyle}" Text="Estimated size" />
                                    <TextBlock x:Name="TempFolderSizeText" FontSize="24" FontFamily="Bahnschrift" FontWeight="SemiBold" />
                                </StackPanel>
                            </Grid>
                            <Button x:Name="OpenTempFolderButton" Click="OpenTempFolderButton_Click" Content="Open Temp Folder" Style="{StaticResource SecondaryActionButtonStyle}" HorizontalAlignment="Left" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <StackPanel Spacing="12">
                <TextBlock x:Name="ProfilesTitleText" FontSize="24" FontFamily="Bahnschrift" FontWeight="SemiBold" Text="Presets" />
                <TextBlock x:Name="ProfilesSubtitleText" Foreground="{StaticResource ShellTextMutedBrush}" Text="Borrowing ZyperWin++ clarity: grouped choices first, actions second." />

                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource PresetCardStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock x:Name="BalancedPresetTitleText" FontSize="18" FontFamily="Bahnschrift" FontWeight="SemiBold" Text="Balanced Tune" />
                            <TextBlock x:Name="BalancedPresetBodyText" Foreground="{StaticResource ShellTextMutedBrush}" TextWrapping="Wrap" Text="Storage cleanup, startup inspection, and update review." />
                            <Button x:Name="BalancedPresetButton" Click="BalancedPresetButton_Click" Style="{StaticResource SecondaryActionButtonStyle}" Content="Select Balanced" HorizontalAlignment="Left" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource PresetCardStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock x:Name="StoragePresetTitleText" FontSize="18" FontFamily="Bahnschrift" FontWeight="SemiBold" Text="Storage Sweep" />
                            <TextBlock x:Name="StoragePresetBodyText" Foreground="{StaticResource ShellTextMutedBrush}" TextWrapping="Wrap" Text="Temp folder review, Storage Sense, and native cleanup surfaces." />
                            <Button x:Name="StoragePresetButton" Click="StoragePresetButton_Click" Style="{StaticResource SecondaryActionButtonStyle}" Content="Select Storage" HorizontalAlignment="Left" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource PresetCardStyle}">
                        <StackPanel Spacing="10">
                            <TextBlock x:Name="StartupPresetTitleText" FontSize="18" FontFamily="Bahnschrift" FontWeight="SemiBold" Text="Boot Focus" />
                            <TextBlock x:Name="StartupPresetBodyText" Foreground="{StaticResource ShellTextMutedBrush}" TextWrapping="Wrap" Text="Startup apps, task pressure, and power behavior tuning." />
                            <Button x:Name="StartupPresetButton" Click="StartupPresetButton_Click" Style="{StaticResource SecondaryActionButtonStyle}" Content="Select Boot" HorizontalAlignment="Left" />
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>

            <Border Style="{StaticResource SectionCardStyle}">
                <StackPanel Spacing="14">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="6">
                            <TextBlock x:Name="ChecklistTitleText" FontSize="24" FontFamily="Bahnschrift" FontWeight="SemiBold" Text="Optimization Checklist" />
                            <TextBlock x:Name="ChecklistSubtitleText" Foreground="{StaticResource ShellTextMutedBrush}" Text="Each entry is explained before launch. No silent destructive actions." />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <Button x:Name="SelectAllButton" Click="SelectAllButton_Click" Style="{StaticResource SecondaryActionButtonStyle}" Content="Select All" />
                            <Button x:Name="ClearSelectionButton" Click="ClearSelectionButton_Click" Style="{StaticResource SecondaryActionButtonStyle}" Content="Clear" />
                        </StackPanel>
                    </Grid>

                    <ListView ItemsSource="{x:Bind Options, Mode=OneWay}" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:OptimizationOption">
                                <Grid Padding="0,12" ColumnSpacing="14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox IsChecked="{x:Bind IsSelected, Mode=TwoWay}" VerticalAlignment="Top" />
                                    <StackPanel Grid.Column="1" Spacing="6">
                                        <TextBlock FontSize="17" FontFamily="Bahnschrift" FontWeight="SemiBold" Text="{x:Bind Title}" />
                                        <TextBlock Foreground="{StaticResource ShellTextMutedBrush}" Text="{x:Bind Description}" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Border Grid.Column="2" Style="{StaticResource TechChipStyle}" VerticalAlignment="Top">
                                        <TextBlock Foreground="{StaticResource ShellAccentSecondaryBrush}" FontFamily="Bahnschrift" Text="{x:Bind Badge}" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
