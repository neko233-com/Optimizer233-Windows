<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Optimizer_Windows.Pages.OptimizePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Optimizer_Windows.Models"
    Background="{StaticResource ShellSurfaceBrush}"
    Loaded="Page_Loaded"
    mc:Ignorable="d">
    <Grid Padding="20" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeroPanelStyle}">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="340" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="8">
                    <Border Style="{StaticResource TechChipStyle}" HorizontalAlignment="Left">
                        <TextBlock x:Name="HeroEyebrowText" FontFamily="Bahnschrift" Foreground="{StaticResource ShellAccentSecondaryBrush}" Text="TACTICAL CONTROL" />
                    </Border>
                    <TextBlock x:Name="ChecklistTitleText" FontSize="28" FontFamily="Bahnschrift" FontWeight="SemiBold" Text="Optimization Checklist" />
                    <TextBlock x:Name="ChecklistSubtitleText" Foreground="{StaticResource ShellTextMutedBrush}" TextWrapping="Wrap" Text="Each entry is explained before launch. No silent destructive actions." />
                </StackPanel>

                <Border Grid.Column="1" Style="{StaticResource InsetPanelStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock x:Name="SelectedTitleText" FontSize="18" FontFamily="Bahnschrift" FontWeight="SemiBold" Text="Selected Items" />
                        <TextBlock x:Name="SelectedItemsText" Foreground="{StaticResource ShellTextMutedBrush}" TextWrapping="Wrap" MaxHeight="92" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.45*" />
                <ColumnDefinition Width="0.95*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}">
                <ListView ItemsSource="{x:Bind Options, Mode=OneWay}" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:OptimizationOption">
                            <Border Margin="0,0,0,10" Style="{StaticResource DataRowCardStyle}">
                                <Grid ColumnSpacing="14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="116" />
                                    </Grid.ColumnDefinitions>

                                    <CheckBox IsChecked="{x:Bind IsSelected, Mode=TwoWay}" Checked="OptionSelectionChanged" Unchecked="OptionSelectionChanged" VerticalAlignment="Top" Margin="0,4,0,0" />

                                    <StackPanel Grid.Column="1" Spacing="6">
                                        <TextBlock FontSize="18" FontFamily="Bahnschrift" FontWeight="SemiBold" Text="{x:Bind Title}" TextWrapping="Wrap" />
                                        <TextBlock Foreground="{StaticResource ShellTextMutedBrush}" Text="{x:Bind Description}" TextWrapping="Wrap" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="8">
                                        <Border Style="{StaticResource StatePillBorderStyle}" Background="{x:Bind BadgeBackground}" BorderBrush="{x:Bind BadgeBorder}" HorizontalAlignment="Right">
                                            <TextBlock Style="{StaticResource PillLabelTextStyle}" Foreground="{x:Bind BadgeForeground}" Text="{x:Bind Badge}" />
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <Grid Grid.Column="1" RowSpacing="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.64*" />
                    <RowDefinition Height="0.36*" />
                </Grid.RowDefinitions>

                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock x:Name="OutputTitleText" FontSize="20" FontFamily="Bahnschrift" FontWeight="SemiBold" Text="Output" />
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="OutputText" Foreground="{StaticResource ShellTextMutedBrush}" TextWrapping="Wrap" />
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource SectionCardStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock x:Name="ActionsPanelTitleText" FontSize="18" FontFamily="Bahnschrift" FontWeight="SemiBold" />
                        <TextBlock x:Name="ActionsPanelBodyText" Foreground="{StaticResource ShellTextMutedBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource SectionCardStyle}" Padding="16">
            <Grid ColumnSpacing="10" RowSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.25*" />
                    <ColumnDefinition Width="1.25*" />
                    <ColumnDefinition Width="1.25*" />
                    <ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Button x:Name="BalancedPresetButton" Grid.Row="0" Grid.Column="0" Click="BalancedPresetButton_Click" Style="{StaticResource SecondaryActionButtonStyle}" Content="Select Balanced" />
                <Button x:Name="StoragePresetButton" Grid.Row="0" Grid.Column="1" Click="StoragePresetButton_Click" Style="{StaticResource SecondaryActionButtonStyle}" Content="Select Storage" />
                <Button x:Name="StartupPresetButton" Grid.Row="0" Grid.Column="2" Click="StartupPresetButton_Click" Style="{StaticResource SecondaryActionButtonStyle}" Content="Select Boot" />
                <Button x:Name="OpenSelectedButton" Grid.Row="0" Grid.Column="3" Click="OpenSelectedButton_Click" Style="{StaticResource PrimaryActionButtonStyle}" Content="Open Selected" />
                <Button x:Name="SelectAllButton" Grid.Row="1" Grid.Column="0" Click="SelectAllButton_Click" Style="{StaticResource SecondaryActionButtonStyle}" Content="Select All" />
                <Button x:Name="ClearSelectionButton" Grid.Row="1" Grid.Column="1" Click="ClearSelectionButton_Click" Style="{StaticResource SecondaryActionButtonStyle}" Content="Clear" />
                <Button x:Name="ExportPlanButton" Grid.Row="1" Grid.Column="2" Click="ExportPlanButton_Click" Style="{StaticResource SecondaryActionButtonStyle}" Content="Export Plan" />
            </Grid>
        </Border>
    </Grid>
</Page>
