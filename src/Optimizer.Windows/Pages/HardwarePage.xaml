<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Optimizer_Windows.Pages.HardwarePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Optimizer_Windows.Models"
    Background="{StaticResource ShellSurfaceBrush}"
    Loaded="Page_Loaded"
    mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Padding="20" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeroPanelStyle}">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="340" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="8">
                    <Border Style="{StaticResource TechChipStyle}" HorizontalAlignment="Left">
                        <TextBlock x:Name="HeroEyebrowText" FontFamily="Bahnschrift" Foreground="{StaticResource ShellAccentSecondaryBrush}" />
                    </Border>
                    <TextBlock x:Name="PageTitleText" FontSize="26" FontFamily="Bahnschrift" FontWeight="SemiBold" />
                    <TextBlock x:Name="PageSubtitleText" Foreground="{StaticResource ShellTextMutedBrush}" TextWrapping="Wrap" />
                </StackPanel>

                <Border Grid.Column="1" Style="{StaticResource SectionCardStyle}" Padding="16">
                    <Grid RowSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="PanelTitleText" FontSize="18" FontFamily="Bahnschrift" FontWeight="SemiBold" />
                            <ProgressRing x:Name="LoadingRing" Width="22" Height="22" IsActive="False" />
                        </Grid>
                        <TextBlock x:Name="StatusText" Grid.Row="1" Foreground="{StaticResource ShellTextMutedBrush}" TextWrapping="Wrap" />
                        <Button x:Name="RefreshButton" Grid.Row="2" Click="RefreshButton_Click" HorizontalAlignment="Left" Style="{StaticResource PrimaryActionButtonStyle}" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock x:Name="CpuSummaryLabelText" Foreground="{StaticResource ShellTextMutedBrush}" FontFamily="Bahnschrift" />
                    <TextBlock x:Name="CpuSummaryValueText" FontSize="18" FontFamily="Bahnschrift" FontWeight="SemiBold" TextWrapping="Wrap" />
                    <TextBlock x:Name="CpuSummaryDetailText" Foreground="{StaticResource ShellTextFaintBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource SectionCardStyle}" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock x:Name="GpuSummaryLabelText" Foreground="{StaticResource ShellTextMutedBrush}" FontFamily="Bahnschrift" />
                    <TextBlock x:Name="GpuSummaryValueText" FontSize="18" FontFamily="Bahnschrift" FontWeight="SemiBold" TextWrapping="Wrap" />
                    <TextBlock x:Name="GpuSummaryDetailText" Foreground="{StaticResource ShellTextFaintBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock x:Name="MemorySummaryLabelText" Foreground="{StaticResource ShellTextMutedBrush}" FontFamily="Bahnschrift" />
                    <TextBlock x:Name="MemorySummaryValueText" FontSize="18" FontFamily="Bahnschrift" FontWeight="SemiBold" TextWrapping="Wrap" />
                    <TextBlock x:Name="MemorySummaryDetailText" Foreground="{StaticResource ShellTextFaintBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Style="{StaticResource SectionCardStyle}" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock x:Name="StorageSummaryLabelText" Foreground="{StaticResource ShellTextMutedBrush}" FontFamily="Bahnschrift" />
                    <TextBlock x:Name="StorageSummaryValueText" FontSize="18" FontFamily="Bahnschrift" FontWeight="SemiBold" TextWrapping="Wrap" />
                    <TextBlock x:Name="StorageSummaryDetailText" Foreground="{StaticResource ShellTextFaintBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource SectionCardStyle}" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock x:Name="NetworkSummaryLabelText" Foreground="{StaticResource ShellTextMutedBrush}" FontFamily="Bahnschrift" />
                    <TextBlock x:Name="NetworkSummaryValueText" FontSize="18" FontFamily="Bahnschrift" FontWeight="SemiBold" TextWrapping="Wrap" />
                    <TextBlock x:Name="NetworkSummaryDetailText" Foreground="{StaticResource ShellTextFaintBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Column="5" Style="{StaticResource SectionCardStyle}" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock x:Name="InputSummaryLabelText" Foreground="{StaticResource ShellTextMutedBrush}" FontFamily="Bahnschrift" />
                    <TextBlock x:Name="InputSummaryValueText" FontSize="18" FontFamily="Bahnschrift" FontWeight="SemiBold" TextWrapping="Wrap" />
                    <TextBlock x:Name="InputSummaryDetailText" Foreground="{StaticResource ShellTextFaintBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" ColumnSpacing="14" RowSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource SectionCardStyle}" Padding="18">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="CpuCardTitleText" FontSize="20" FontFamily="Bahnschrift" FontWeight="SemiBold" />
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{x:Bind CpuItems, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:DetailItem">
                                    <Grid Padding="0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontFamily="Bahnschrift" FontWeight="SemiBold" Text="{x:Bind Label}" />
                                        <TextBlock Grid.Column="1" Foreground="{StaticResource ShellTextMutedBrush}" Text="{x:Bind Value}" TextWrapping="Wrap" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource SectionCardStyle}" Padding="18">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="GpuCardTitleText" FontSize="20" FontFamily="Bahnschrift" FontWeight="SemiBold" />
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{x:Bind GpuItems, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:DetailItem">
                                    <Grid Padding="0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="220" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontFamily="Bahnschrift" FontWeight="SemiBold" Text="{x:Bind Label}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="1" Foreground="{StaticResource ShellTextMutedBrush}" Text="{x:Bind Value}" TextWrapping="Wrap" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource SectionCardStyle}" Padding="18">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="MemoryCardTitleText" FontSize="20" FontFamily="Bahnschrift" FontWeight="SemiBold" />
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{x:Bind MemoryItems, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:DetailItem">
                                    <Grid Padding="0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontFamily="Bahnschrift" FontWeight="SemiBold" Text="{x:Bind Label}" />
                                        <TextBlock Grid.Column="1" Foreground="{StaticResource ShellTextMutedBrush}" Text="{x:Bind Value}" TextWrapping="Wrap" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource SectionCardStyle}" Padding="18">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="StorageCardTitleText" FontSize="20" FontFamily="Bahnschrift" FontWeight="SemiBold" />
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{x:Bind StorageItems, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:DetailItem">
                                    <Grid Padding="0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="220" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontFamily="Bahnschrift" FontWeight="SemiBold" Text="{x:Bind Label}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="1" Foreground="{StaticResource ShellTextMutedBrush}" Text="{x:Bind Value}" TextWrapping="Wrap" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource SectionCardStyle}" Padding="18">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="NetworkCardTitleText" FontSize="20" FontFamily="Bahnschrift" FontWeight="SemiBold" />
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{x:Bind NetworkItems, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:DetailItem">
                                    <Grid Padding="0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="220" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontFamily="Bahnschrift" FontWeight="SemiBold" Text="{x:Bind Label}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="1" Foreground="{StaticResource ShellTextMutedBrush}" Text="{x:Bind Value}" TextWrapping="Wrap" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource SectionCardStyle}" Padding="18">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="InputCardTitleText" FontSize="20" FontFamily="Bahnschrift" FontWeight="SemiBold" />
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{x:Bind InputItems, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:DetailItem">
                                    <Grid Padding="0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="220" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontFamily="Bahnschrift" FontWeight="SemiBold" Text="{x:Bind Label}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="1" Foreground="{StaticResource ShellTextMutedBrush}" Text="{x:Bind Value}" TextWrapping="Wrap" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
    </ScrollViewer>
</Page>
