<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Optimizer_Windows.Pages.HardwarePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Optimizer_Windows.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Optimizer_Windows.Models"
    Loaded="Page_Loaded"
    mc:Ignorable="d">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24,20,24,32" Spacing="20">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="6">
                    <TextBlock x:Name="PageTitleText" Style="{StaticResource TitleTextBlockStyle}" Text="Hardware" />
                    <TextBlock x:Name="PageSubtitleText" Opacity="0.78" Text="Live inventory from Windows device APIs and WMI." />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <ProgressRing x:Name="LoadingRing" Width="24" Height="24" IsActive="False" />
                    <Button x:Name="RefreshButton" Click="RefreshButton_Click" Content="Refresh" />
                </StackPanel>
            </Grid>

            <TextBlock x:Name="StatusText" Opacity="0.68" />

            <Expander x:Name="CpuExpander" Header="CPU" IsExpanded="True">
                <ListView ItemsSource="{x:Bind CpuItems, Mode=OneWay}" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:DetailItem">
                            <Grid Padding="0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock FontWeight="SemiBold" Text="{x:Bind Label}" />
                                <TextBlock Grid.Column="1" Opacity="0.78" Text="{x:Bind Value}" TextWrapping="Wrap" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Expander>

            <Expander x:Name="GpuExpander" Header="GPU" IsExpanded="True">
                <ListView ItemsSource="{x:Bind GpuItems, Mode=OneWay}" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:DetailItem">
                            <Grid Padding="0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock FontWeight="SemiBold" Text="{x:Bind Label}" />
                                <TextBlock Grid.Column="1" Opacity="0.78" Text="{x:Bind Value}" TextWrapping="Wrap" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Expander>

            <Expander x:Name="MemoryExpander" Header="Memory" IsExpanded="True">
                <ListView ItemsSource="{x:Bind MemoryItems, Mode=OneWay}" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:DetailItem">
                            <Grid Padding="0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock FontWeight="SemiBold" Text="{x:Bind Label}" />
                                <TextBlock Grid.Column="1" Opacity="0.78" Text="{x:Bind Value}" TextWrapping="Wrap" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Expander>

            <Expander x:Name="StorageExpander" Header="Storage" IsExpanded="True">
                <ListView ItemsSource="{x:Bind StorageItems, Mode=OneWay}" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:DetailItem">
                            <Grid Padding="0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock FontWeight="SemiBold" Text="{x:Bind Label}" />
                                <TextBlock Grid.Column="1" Opacity="0.78" Text="{x:Bind Value}" TextWrapping="Wrap" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Expander>

            <Expander x:Name="NetworkExpander" Header="Network" IsExpanded="True">
                <ListView ItemsSource="{x:Bind NetworkItems, Mode=OneWay}" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:DetailItem">
                            <Grid Padding="0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock FontWeight="SemiBold" Text="{x:Bind Label}" />
                                <TextBlock Grid.Column="1" Opacity="0.78" Text="{x:Bind Value}" TextWrapping="Wrap" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Expander>
        </StackPanel>
    </ScrollViewer>
</Page>
