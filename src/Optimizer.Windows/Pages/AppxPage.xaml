<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Optimizer_Windows.Pages.AppxPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Optimizer_Windows.Models"
    Background="{StaticResource ShellSurfaceBrush}"
    Loaded="Page_Loaded"
    mc:Ignorable="d">
    <Grid Padding="16" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Style="{StaticResource SectionCardStyle}">
            <StackPanel Spacing="12">
                <TextBlock x:Name="PageTitleText" FontSize="22" FontFamily="Bahnschrift" FontWeight="SemiBold" Text="Appx Management" />
                <TextBlock x:Name="PageSubtitleText" Foreground="{StaticResource ShellTextMutedBrush}" TextWrapping="Wrap" Text="Inspect installed Appx packages and remove selected current-user apps." />
                <TextBlock x:Name="StatusText" Foreground="{StaticResource ShellTextMutedBrush}" TextWrapping="Wrap" />
                <ListView ItemsSource="{x:Bind Packages, Mode=OneWay}" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:AppxPackageInfo">
                            <Grid Padding="0,8" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <CheckBox IsChecked="{x:Bind IsSelected, Mode=TwoWay}" VerticalAlignment="Top" />
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock FontSize="16" FontFamily="Bahnschrift" FontWeight="SemiBold" Text="{x:Bind Name}" />
                                    <TextBlock Foreground="{StaticResource ShellTextMutedBrush}" Text="{x:Bind Publisher}" TextWrapping="Wrap" />
                                    <TextBlock Foreground="{StaticResource ShellTextFaintBrush}" Text="{x:Bind Version}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button x:Name="RefreshButton" Grid.Column="0" Click="RefreshButton_Click" Style="{StaticResource SecondaryActionButtonStyle}" Content="Refresh" />
            <Button x:Name="RemoveButton" Grid.Column="1" Click="RemoveButton_Click" Style="{StaticResource PrimaryActionButtonStyle}" Content="Remove Selected" />
        </Grid>
    </Grid>
</Page>
