<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Optimizer_Windows.Pages.WslPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Optimizer_Windows.Models"
    Background="{StaticResource ShellSurfaceBrush}"
    Loaded="Page_Loaded"
    Unloaded="Page_Unloaded"
    mc:Ignorable="d">
    <Grid Padding="20" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeroPanelStyle}">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="340" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="8">
                    <Border Style="{StaticResource TechChipStyle}" HorizontalAlignment="Left">
                        <TextBlock x:Name="HeroEyebrowText" FontFamily="Bahnschrift" Foreground="{StaticResource ShellAccentSecondaryBrush}" />
                    </Border>
                    <TextBlock x:Name="PageTitleText" FontSize="26" FontFamily="Bahnschrift" FontWeight="SemiBold" />
                    <TextBlock x:Name="PageSubtitleText" Foreground="{StaticResource ShellTextMutedBrush}" TextWrapping="Wrap" />
                </StackPanel>

                <Border Grid.Column="1" Style="{StaticResource InsetPanelStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock x:Name="StatusCardTitleText" FontSize="18" FontFamily="Bahnschrift" FontWeight="SemiBold" />
                        <TextBlock x:Name="StatusText" Foreground="{StaticResource ShellTextMutedBrush}" TextWrapping="Wrap" />
                        <Button x:Name="RefreshButton" Click="RefreshButton_Click" HorizontalAlignment="Left" Style="{StaticResource SecondaryActionButtonStyle}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock x:Name="DistroMetricLabelText" Foreground="{StaticResource ShellTextMutedBrush}" FontFamily="Bahnschrift" />
                    <TextBlock x:Name="DistroMetricValueText" Style="{StaticResource MetricValueTextStyle}" />
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource SectionCardStyle}" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock x:Name="RunningMetricLabelText" Foreground="{StaticResource ShellTextMutedBrush}" FontFamily="Bahnschrift" />
                    <TextBlock x:Name="RunningMetricValueText" Style="{StaticResource MetricValueTextStyle}" />
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock x:Name="VersionMetricLabelText" Foreground="{StaticResource ShellTextMutedBrush}" FontFamily="Bahnschrift" />
                    <TextBlock x:Name="VersionMetricValueText" Style="{StaticResource MetricValueTextStyle}" />
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Style="{StaticResource SectionCardStyle}" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock x:Name="DefaultMetricLabelText" Foreground="{StaticResource ShellTextMutedBrush}" FontFamily="Bahnschrift" />
                    <TextBlock x:Name="DefaultMetricValueText" FontSize="22" FontFamily="Bahnschrift" FontWeight="SemiBold" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource SectionCardStyle}" Padding="18">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchBox" PlaceholderText="Search distro, running, version..." TextChanged="SearchBox_TextChanged" />
                <Button x:Name="InstallButton" Grid.Column="1" Click="InstallButton_Click" Style="{StaticResource SecondaryActionButtonStyle}" />
                <Button x:Name="UpdateButton" Grid.Column="2" Click="UpdateButton_Click" Style="{StaticResource SecondaryActionButtonStyle}" />
                <Button x:Name="ShutdownButton" Grid.Column="3" Click="ShutdownButton_Click" Style="{StaticResource PrimaryActionButtonStyle}" />
            </Grid>
        </Border>

        <Grid Grid.Row="3" ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.1*" />
                <ColumnDefinition Width="0.9*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}" Padding="18">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="DistrosTitleText" FontSize="20" FontFamily="Bahnschrift" FontWeight="SemiBold" />
                    <ListView Grid.Row="1" ItemsSource="{x:Bind VisibleDistros, Mode=OneWay}" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:WslDistroInfo">
                                <Border Margin="0,0,0,10" Style="{StaticResource InsetPanelStyle}" Padding="14">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="90" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="6">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock FontSize="16" FontFamily="Bahnschrift" FontWeight="SemiBold" Text="{x:Bind Name}" />
                                                <Border Style="{StaticResource PillTagBorderStyle}" Background="#15101A" BorderBrush="{StaticResource ShellAccentDimBrush}" Padding="10,3" MinWidth="0" Visibility="{x:Bind DefaultBadgeVisibility, Mode=OneTime}">
                                                    <TextBlock Style="{StaticResource PillLabelTextStyle}" Foreground="{StaticResource ShellAccentSecondaryBrush}" Text="DEFAULT" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Foreground="{StaticResource ShellTextMutedBrush}" Text="{x:Bind StateLabel}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Text="{x:Bind VersionLabel}" />
                                        <TextBlock Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" Text="{x:Bind State}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <TextBlock x:Name="EmptyStateText" Grid.Row="1" Margin="0,12,0,0" Foreground="{StaticResource ShellTextFaintBrush}" TextWrapping="Wrap" Visibility="Collapsed" />
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource SectionCardStyle}" Padding="18">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="RawStatusTitleText" FontSize="20" FontFamily="Bahnschrift" FontWeight="SemiBold" />
                    <TextBlock x:Name="ActionHintText" Foreground="{StaticResource ShellTextMutedBrush}" TextWrapping="Wrap" />
                    <Button x:Name="OpenShellButton" Click="OpenShellButton_Click" Style="{StaticResource SecondaryActionButtonStyle}" />
                    <Button x:Name="OpenDocsButton" Click="OpenDocsButton_Click" Style="{StaticResource SecondaryActionButtonStyle}" />
                    <ScrollViewer Height="320" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="RawStatusText" FontFamily="Consolas" TextWrapping="Wrap" />
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
