<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Optimizer_Windows.Pages.CleanupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Optimizer_Windows.Models"
    Background="{StaticResource ShellSurfaceBrush}"
    Loaded="Page_Loaded"
    Unloaded="Page_Unloaded"
    mc:Ignorable="d">
    <Grid Padding="20" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeroPanelStyle}">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="340" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="8">
                    <TextBlock x:Name="PageTitleText" FontSize="26" FontFamily="Bahnschrift" FontWeight="SemiBold" />
                    <TextBlock x:Name="PageSubtitleText" Foreground="{StaticResource ShellTextMutedBrush}" TextWrapping="Wrap" />
                </StackPanel>

                <Border Grid.Column="1" Style="{StaticResource InsetPanelStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock x:Name="SummaryCardTitleText" FontSize="18" FontFamily="Bahnschrift" FontWeight="SemiBold" Text="Scan Summary" />
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <ProgressRing x:Name="ScanProgressRing" Width="18" Height="18" IsActive="False" Visibility="Collapsed" />
                            <TextBlock x:Name="SummaryText" Foreground="{StaticResource ShellTextMutedBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock x:Name="TargetsLabelText" Foreground="{StaticResource ShellTextMutedBrush}" FontFamily="Bahnschrift" Text="Targets" />
                    <TextBlock x:Name="TargetsValueText" FontSize="22" FontFamily="Bahnschrift" FontWeight="SemiBold" />
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource SectionCardStyle}" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock x:Name="FilesLabelText" Foreground="{StaticResource ShellTextMutedBrush}" FontFamily="Bahnschrift" Text="Files" />
                    <TextBlock x:Name="FilesValueText" FontSize="22" FontFamily="Bahnschrift" FontWeight="SemiBold" />
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}" Padding="16">
                <StackPanel Spacing="6">
                    <TextBlock x:Name="SizeLabelText" Foreground="{StaticResource ShellTextMutedBrush}" FontFamily="Bahnschrift" Text="Estimated Size" />
                    <TextBlock x:Name="SizeValueText" FontSize="22" FontFamily="Bahnschrift" FontWeight="SemiBold" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.15*" />
                <ColumnDefinition Width="0.85*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}" Padding="18">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="TargetsListTitleText" FontSize="20" FontFamily="Bahnschrift" FontWeight="SemiBold" />
                    <Grid Grid.Row="1" ColumnSpacing="12" Margin="0,2,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="96" />
                            <ColumnDefinition Width="116" />
                            <ColumnDefinition Width="112" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="LegendTargetText" Foreground="{StaticResource ShellTextFaintBrush}" />
                        <TextBlock x:Name="LegendFilesText" Grid.Column="1" Foreground="{StaticResource ShellTextFaintBrush}" HorizontalAlignment="Center" />
                        <TextBlock x:Name="LegendSizeText" Grid.Column="2" Foreground="{StaticResource ShellTextFaintBrush}" HorizontalAlignment="Center" />
                        <TextBlock x:Name="LegendActionText" Grid.Column="3" Foreground="{StaticResource ShellTextFaintBrush}" HorizontalAlignment="Right" />
                    </Grid>
                    <ListView x:Name="TargetsListView" Grid.Row="2" ItemsSource="{x:Bind CleanupTargets, Mode=OneWay}" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:CleanupTargetResult">
                                <Border Margin="0,0,0,10" Style="{StaticResource DataRowCardStyle}">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="96" />
                                            <ColumnDefinition Width="116" />
                                            <ColumnDefinition Width="112" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="6">
                                            <TextBlock FontSize="16" FontFamily="Bahnschrift" FontWeight="SemiBold" Text="{x:Bind Title}" />
                                            <TextBlock Foreground="{StaticResource ShellTextMutedBrush}" Text="{x:Bind Description}" TextWrapping="Wrap" />
                                            <TextBlock Foreground="{StaticResource ShellTextFaintBrush}" Text="{x:Bind Path}" TextWrapping="WrapWholeWords" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                            <TextBlock Foreground="{StaticResource ShellTextFaintBrush}" FontSize="12" HorizontalAlignment="Center" Text="{x:Bind FileCountCaption}" />
                                            <TextBlock HorizontalAlignment="Center" Text="{x:Bind FileCountLabel}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="4">
                                            <TextBlock Foreground="{StaticResource ShellTextFaintBrush}" FontSize="12" HorizontalAlignment="Center" Text="{x:Bind SizeCaption}" />
                                            <TextBlock HorizontalAlignment="Center" Text="{x:Bind SizeLabel}" />
                                        </StackPanel>
                                        <Button Grid.Column="3" Width="104" Click="CleanTargetButton_Click" HorizontalAlignment="Right" Style="{StaticResource SecondaryActionButtonStyle}" Content="{x:Bind ActionLabel}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <TextBlock
                        x:Name="EmptyStateText"
                        Grid.Row="2"
                        Margin="0,12,0,0"
                        Foreground="{StaticResource ShellTextFaintBrush}"
                        TextWrapping="Wrap"
                        Visibility="Collapsed" />
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource SectionCardStyle}" Padding="18">
                <StackPanel Spacing="12">
                    <TextBlock x:Name="ActionsTitleText" FontSize="20" FontFamily="Bahnschrift" FontWeight="SemiBold" Text="Actions" />
                    <TextBlock x:Name="ActionsHintText" Foreground="{StaticResource ShellTextMutedBrush}" TextWrapping="Wrap" />
                    <Button x:Name="AnalyzeButton" Click="AnalyzeButton_Click" Style="{StaticResource SecondaryActionButtonStyle}" />
                    <Button x:Name="CancelScanButton" Click="CancelScanButton_Click" Style="{StaticResource SecondaryActionButtonStyle}" />
                    <Button x:Name="CleanButton" Click="CleanButton_Click" Style="{StaticResource PrimaryActionButtonStyle}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
